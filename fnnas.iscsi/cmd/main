#!/bin/bash

export PATH=/var/apps/nodejs_v22/target/bin:$PATH

LOG_FILE="${TRIM_PKGVAR}/iscsi.log"
PID_FILE="${TRIM_PKGVAR}/iscsi.pid"
SOCKET_FILE="${TRIM_APPDEST}/iscsi.sock"

export TRIM_APPDEST TRIM_PKGETC TRIM_PKGVAR

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "${LOG_FILE}"
}

start() {
    if [ -f "$PID_FILE" ]; then
        local pid
        pid=$(cat "$PID_FILE")
        if kill -0 "$pid" 2>/dev/null; then
            log_msg "Already running (PID: $pid)"
            exit 0
        fi
        rm -f "$PID_FILE"
    fi

    rm -f "$SOCKET_FILE"
    mkdir -p "$TRIM_PKGVAR"
    mkdir -p "$TRIM_PKGETC"

    log_msg "Starting iSCSI backend..."
    node "${TRIM_APPDEST}/server.js" >> "${LOG_FILE}" 2>&1 &
    printf "%s" "$!" > "$PID_FILE"
    log_msg "Started (PID: $!)"
    exit 0
}

stop() {
    if [ -f "$PID_FILE" ]; then
        local pid
        pid=$(cat "$PID_FILE")
        if kill -0 "$pid" 2>/dev/null; then
            log_msg "Stopping (PID: $pid)..."
            kill "$pid"
            local count=0
            while kill -0 "$pid" 2>/dev/null && [ $count -lt 10 ]; do
                sleep 1
                count=$((count + 1))
            done
            if kill -0 "$pid" 2>/dev/null; then
                kill -9 "$pid"
            fi
        fi
        rm -f "$PID_FILE"
    fi
    rm -f "$SOCKET_FILE"
    log_msg "Stopped"
    exit 0
}

status() {
    if [ -f "$PID_FILE" ]; then
        local pid
        pid=$(cat "$PID_FILE")
        if kill -0 "$pid" 2>/dev/null; then
            exit 0
        fi
    fi
    exit 3
}

case "$1" in
    start)  start ;;
    stop)   stop ;;
    status) status ;;
    *)      exit 1 ;;
esac
