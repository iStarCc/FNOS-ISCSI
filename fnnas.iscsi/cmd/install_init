#!/bin/bash

if command -v iscsiadm &>/dev/null; then
    exit 0
fi

# 尝试自动安装 open-iscsi
if command -v apt-get &>/dev/null; then
    apt-get update -qq && apt-get install -y -qq open-iscsi >/dev/null 2>&1
    if command -v iscsiadm &>/dev/null; then
        systemctl enable iscsid 2>/dev/null
        systemctl start iscsid 2>/dev/null
        exit 0
    fi
fi

if [ -n "$TRIM_TEMP_LOGFILE" ]; then
    echo "系统未安装 open-iscsi，请先执行: apt install open-iscsi" >> "$TRIM_TEMP_LOGFILE"
fi
exit 1
